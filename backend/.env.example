# Optional: restrict this backend to specific algorithms (Option A: two backends).
# Main backend (HGS, GLS, ACO, SA):  BACKEND_ALGOS=hgs,gls,aco,sa
# ILS backend (ILS only):            BACKEND_ALGOS=ils
# Omit to auto-detect (4 algos + ils if pyvrp>=0.13 is installed).

# Paths
DATASET_PATH=dataset

# Optional
DEFAULT_RUNTIME=120

